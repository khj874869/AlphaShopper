{
  "title": "AlphaShopper Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Backend RPS",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{service=\"zigzag-backend\",uri!~\"/actuator.*\"}[5m]))",
          "legendFormat": "stable"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Backend 5xx Ratio",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{service=\"zigzag-backend\",status=~\"5..\",uri!~\"/actuator.*\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{service=\"zigzag-backend\",uri!~\"/actuator.*\"}[5m])), 0.001)",
          "legendFormat": "stable"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Backend P95 Latency",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{service=\"zigzag-backend\",uri!~\"/actuator.*\"}[5m])))",
          "legendFormat": "stable"
        }
      ]
    },
    {
      "type": "stat",
      "title": "DLT Replay Failures 15m",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(alphashopper_kafka_dlt_replay_results_total{result=~\"failed|exception\"}[15m]))",
          "legendFormat": "failures"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backend Requests By Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{service=\"zigzag-backend\",uri!~\"/actuator.*\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backend P95 Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{service=\"zigzag-backend\",uri!~\"/actuator.*\"}[5m])))",
          "legendFormat": "stable"
        }
      ]
    }
  ]
}
