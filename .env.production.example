SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus

DB_URL=jdbc:postgresql://db.example.internal:5432/alphashopper
DB_USERNAME=alphashopper
DB_PASSWORD=change-me
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_CLEAN_DISABLED=true
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
SPRING_FLYWAY_OUT_OF_ORDER=false

APP_JWT_SECRET=replace-with-a-long-random-secret
APP_JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=180
APP_AUTH_COOKIE_SECURE=true
APP_AUTH_COOKIE_SAME_SITE=Lax
APP_FRONTEND_BASE_URL=https://shop.example.com
APP_FRONTEND_ALLOWED_ORIGINS=https://shop.example.com
APP_PAYMENT_PROVIDER=toss
APP_PAYMENT_TOSS_SECRET_KEY=live_sk_your_secret_key
APP_SEED_DEMO_DATA_ENABLED=false
APP_AI_LLM_ENABLED=true
APP_AI_LLM_BASE_URL=https://llm-gateway.example.internal
APP_AI_LLM_API_KEY=change-me
APP_AI_LLM_MODEL=alphashopper-assistant
APP_AI_LLM_TIMEOUT_MS=8000
APP_AI_RECOMMENDATION_CLICK_SIGNAL_ENABLED=true
APP_AI_RECOMMENDATION_CLICK_SIGNAL_WINDOW_DAYS=30
APP_AI_RECOMMENDATION_CLICK_SIGNAL_BOOST_PER_CLICK=2
APP_AI_RECOMMENDATION_CLICK_SIGNAL_MAX_CLICK_BOOST=8
APP_AI_RECOMMENDATION_CLICK_SIGNAL_TOP_RANK_THRESHOLD=2.0
APP_AI_RECOMMENDATION_CLICK_SIGNAL_TOP_RANK_BOOST=2
APP_AI_RECOMMENDATION_CLICK_SIGNAL_MID_RANK_THRESHOLD=5.0
APP_AI_RECOMMENDATION_CLICK_SIGNAL_MID_RANK_BOOST=1
APP_AI_RECOMMENDATION_CTR_SIGNAL_ENABLED=true
APP_AI_RECOMMENDATION_CTR_SIGNAL_MIN_IMPRESSIONS=5
APP_AI_RECOMMENDATION_CTR_SIGNAL_HIGH_THRESHOLD=0.35
APP_AI_RECOMMENDATION_CTR_SIGNAL_HIGH_BOOST=3
APP_AI_RECOMMENDATION_CTR_SIGNAL_MID_THRESHOLD=0.15
APP_AI_RECOMMENDATION_CTR_SIGNAL_MID_BOOST=1
APP_AI_RECOMMENDATION_CTR_SIGNAL_LOW_THRESHOLD=0.03
APP_AI_RECOMMENDATION_CTR_SIGNAL_LOW_PENALTY=1
APP_AI_RECOMMENDATION_CTR_SIGNAL_LOW_ACTION=PENALIZE
APP_AI_RECOMMENDATION_EXPERIMENT_ENABLED=false
APP_AI_RECOMMENDATION_EXPERIMENT_CTR_TREATMENT_PERCENT=50

APP_SEARCH_ENABLED=true
APP_SEARCH_REINDEX_ON_STARTUP=false
APP_SEARCH_RECREATE_INDEX_ON_REINDEX=false
ELASTICSEARCH_URL=https://search.example.com:9200

APP_KAFKA_AUTO_CREATE_TOPICS=false
APP_KAFKA_ORDER_NOTIFICATIONS_TOPIC=order-notifications
APP_KAFKA_ORDER_NOTIFICATIONS_DLT_TOPIC=order-notifications.DLT
APP_KAFKA_NOTIFICATION_RETRY_MAX_ATTEMPTS=3
APP_KAFKA_NOTIFICATION_RETRY_BACKOFF_MS=1000
APP_KAFKA_NOTIFICATION_DLT_REPLAY_CONSUMER_GROUP_ID=zigzag-notification-dlt-replay
APP_KAFKA_NOTIFICATION_DLT_REPLAY_POLL_TIMEOUT_MS=3000
APP_KAFKA_NOTIFICATION_DLT_REPLAY_SEND_TIMEOUT_MS=10000
KAFKA_BOOTSTRAP_SERVERS=kafka-1.example.internal:9092
KAFKA_CONSUMER_GROUP_ID=zigzag-notification-consumer

APP_MAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=change-me
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
