SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus

DB_URL=jdbc:postgresql://db.example.internal:5432/alphashopper
DB_USERNAME=alphashopper
DB_PASSWORD=change-me
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_CLEAN_DISABLED=true
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
SPRING_FLYWAY_OUT_OF_ORDER=false

APP_JWT_SECRET=replace-with-a-long-random-secret
APP_JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=180
APP_AUTH_COOKIE_SECURE=true
APP_AUTH_COOKIE_SAME_SITE=Lax
APP_FRONTEND_BASE_URL=https://shop.example.com
APP_FRONTEND_ALLOWED_ORIGINS=https://shop.example.com
APP_PAYMENT_PROVIDER=toss
APP_PAYMENT_TOSS_SECRET_KEY=live_sk_your_secret_key
APP_SEED_DEMO_DATA_ENABLED=false

APP_SEARCH_ENABLED=true
APP_SEARCH_REINDEX_ON_STARTUP=false
ELASTICSEARCH_URL=https://search.example.com:9200

APP_KAFKA_AUTO_CREATE_TOPICS=false
APP_KAFKA_ORDER_NOTIFICATIONS_TOPIC=order-notifications
KAFKA_BOOTSTRAP_SERVERS=kafka-1.example.internal:9092
KAFKA_CONSUMER_GROUP_ID=zigzag-notification-consumer

APP_MAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=change-me
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
